# Build contexts relative to docker-compose.yml
JOURNEY_READ_CONTEXT=./journey-resolution-read
JOURNEY_BFF_CONTEXT=./services/journey-bff
FRONTEND_CONTEXT=./frontend

# Host ports
FRONTEND_HOST_PORT=3000
JOURNEY_BFF_HOST_PORT=8080
JOURNEY_READ_HOST_PORT=8081
POSTGRES_HOST_PORT=5433
KAFKA_HOST_PORT=9092

# PostgreSQL
POSTGRES_DB=journey_resolution
POSTGRES_USER=journey
POSTGRES_PASSWORD=journey

# Must be identical to the secret used to generate subjectKey in the BFF.
JOURNEY_SUBJECT_KEY_SECRET=local-development-secret-change-me

# This URL is used by the browser, not by the Docker network.
NEXT_PUBLIC_JOURNEY_API_URL=http://localhost:8080
